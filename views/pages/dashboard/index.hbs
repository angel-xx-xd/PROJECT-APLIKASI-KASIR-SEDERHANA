<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h3 class="fw-bold mb-1">Dashboard Kasir</h3>
        <p class="text-muted mb-0">
            Selamat datang, <strong>{{session.nama}}</strong> — Ringkasan Aplikasi Kasir
        </p>
    </div>

    <a href="/transaksi/create" class="btn btn-outline-primary">
        Buat Transaksi
    </a>
</div>

<!-- Statistik -->
<div class="row g-3 mb-4">

    <div class="col-xl-3 col-md-6">
        <div class="card border-0 shadow-sm h-100" style="border-left:4px solid #0d6efd">
            <div class="card-body text-center">
                <h4 class="text-primary">{{stats.totalProduk}}</h4>
                <small class="text-muted">Total Produk</small>
            </div>
        </div>
    </div>

    <div class="col-xl-3 col-md-6">
        <div class="card border-0 shadow-sm h-100" style="border-left:4px solid #198754">
            <div class="card-body text-center">
                <h4 class="text-success">{{stats.totalKategori}}</h4>
                <small class="text-muted">Kategori</small>
            </div>
        </div>
    </div>

    <div class="col-xl-3 col-md-6">
        <div class="card border-0 shadow-sm h-100" style="border-left:4px solid #fd7e14">
            <div class="card-body text-center">
                <h4 class="text-warning">Rp {{stats.totalPenjualan}}</h4>
                <small class="text-muted">Total Penjualan</small>
            </div>
        </div>
    </div>

    <div class="col-xl-3 col-md-6">
        <div class="card border-0 shadow-sm h-100" style="border-left:4px solid #dc3545">
            <div class="card-body text-center">
                <h4 class="text-danger">{{stats.totalTransaksi}}</h4>
                <small class="text-muted">Transaksi</small>
            </div>
        </div>
    </div>

</div>

<!-- Data Produk -->
<div class="row g-3 mb-4">

    <div class="col-md-6">

        <div class="card border-0 shadow-sm">

            <div class="card-header bg-white d-flex justify-content-between">

                <h6 class="fw-bold mb-0">Produk Terbaru</h6>

                <a href="/produk/list" class="btn btn-sm btn-outline-primary">
                    Lihat Semua
                </a>

            </div>

            <div class="card-body p-0">

                <table class="table table-hover mb-0">

                    <thead class="table-light">

                        <tr>

                            <th>Produk</th>
                            <th>Harga</th>
                            <th>Stok</th>

                        </tr>

                    </thead>

                    <tbody>

                        {{#each stats.produkTerbaru}}

                        <tr>

                            <td>{{nama_produk}}</td>

                            <td>Rp {{harga}}</td>

                            <td>{{stok}}</td>

                        </tr>

                        {{/each}}

                    </tbody>

                </table>

            </div>

        </div>

    </div>

    <div class="col-md-6">

        <div class="card border-0 shadow-sm">

            <div class="card-header bg-white d-flex justify-content-between">

                <h6 class="fw-bold mb-0">Transaksi Terbaru</h6>

                <a href="/transaksi/list" class="btn btn-sm btn-outline-primary">
                    Lihat Semua
                </a>

            </div>

            <div class="card-body p-0">

                <table class="table table-hover mb-0">

                    <thead class="table-light">

                        <tr>

                            <th>ID</th>

                            <th>Tanggal</th>

                            <th>Total</th>

                        </tr>

                    </thead>

                    <tbody>

                        {{#each stats.transaksiTerbaru}}

                        <tr>

                            <td>#{{id}}</td>

                            <td>{{tanggal}}</td>

                            <td>Rp {{total}}</td>

                        </tr>

                        {{/each}}

                    </tbody>

                </table>

            </div>

        </div>

    </div>

</div>