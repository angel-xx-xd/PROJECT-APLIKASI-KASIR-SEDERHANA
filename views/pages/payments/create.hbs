<h2 class="mb-4">

    Pembayaran

</h2>

{{#if pesanError.length}}

<div class="alert alert-danger">

    <ul>

        {{#each pesanError}}

        <li>{{this}}</li>

        {{/each}}

    </ul>

</div>

{{/if}}

<form action="/pembayaran/create" method="POST">

    <div class="mb-3">

        <label class="form-label">

            Transaksi

        </label>

        <select
            name="transaction_id"
            class="form-select"
            required>

            <option value="">

                -- Pilih Transaksi --

            </option>

            {{#each transaksi}}

            <option value="{{id}}">

                #{{id}} | {{nama}} | Rp {{total}}

            </option>

            {{/each}}

        </select>

    </div>

    <div class="mb-3">

        <label class="form-label">

            Metode Pembayaran

        </label>

        <select
            name="metode_pembayaran"
            class="form-select"
            required>

            <option value="Tunai">Tunai</option>
            <option value="QRIS">QRIS</option>
            <option value="Transfer">Transfer</option>
            <option value="Debit">Debit</option>

        </select>

    </div>

    <div class="mb-3">

        <label class="form-label">

            Jumlah Bayar

        </label>

        <input
            type="number"
            name="jumlah_bayar"
            class="form-control"
            required>

    </div>

    <button class="btn btn-success">

        Simpan Pembayaran

    </button>

    <a
        href="/pembayaran/list"
        class="btn btn-secondary">

        Batal

    </a>

</form>