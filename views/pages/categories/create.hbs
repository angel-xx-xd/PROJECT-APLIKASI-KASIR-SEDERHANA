<h1 class="mb-4">

    Tambah Kategori

</h1>

{{#if pesanError.length}}

<div class="alert alert-danger">

    <ul class="mb-0">

        {{#each pesanError}}

        <li>{{this}}</li>

        {{/each}}

    </ul>

</div>

{{/if}}

<form
    action="/kategori/create"
    method="POST">

    <div class="mb-3">

        <label class="form-label">

            Nama Kategori

        </label>

        <input
            type="text"
            name="nama_kategori"
            class="form-control"
            value="{{formData.nama_kategori}}">

    </div>

    <button
        type="submit"
        class="btn btn-success">

        Simpan

    </button>

    <a
        href="/kategori/list"
        class="btn btn-secondary">

        Kembali

    </a>

</form>