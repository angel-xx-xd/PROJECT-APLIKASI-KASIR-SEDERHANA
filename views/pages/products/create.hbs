<div class="d-flex justify-content-between align-items-center mb-3">
    <h1>Tambah Produk</h1>

    <a href="/produk/list" class="btn btn-secondary">
        Kembali
    </a>
</div>

{{#if pesanError.length}}

<div class="alert alert-danger">

    <ul class="mb-0">

        {{#each pesanError}}
        <li>{{this}}</li>
        {{/each}}

    </ul>

</div>

{{/if}}

<div class="card">

    <div class="card-body">

        <form action="/produk/create" method="POST">

            <div class="mb-3">

                <label class="form-label">Kategori</label>

                <select name="category_id" class="form-control">

                    {{#each kategori}}

                    <option value="{{this.id}}">
                        {{this.nama_kategori}}
                    </option>

                    {{/each}}

                </select>

            </div>

            <div class="mb-3">

                <label class="form-label">Nama Produk</label>

                <input
                    type="text"
                    name="nama_produk"
                    class="form-control"
                    value="{{formData.nama_produk}}">

            </div>

            <div class="mb-3">

                <label class="form-label">Harga</label>

                <input
                    type="number"
                    name="harga"
                    class="form-control"
                    value="{{formData.harga}}">

            </div>

            <div class="mb-3">

                <label class="form-label">Stok</label>

                <input
                    type="number"
                    name="stok"
                    class="form-control"
                    value="{{formData.stok}}">

            </div>

            <button class="btn btn-success">
                Simpan
            </button>

            <a href="/produk/list" class="btn btn-secondary">
                Batal
            </a>

        </form>

    </div>

</div>