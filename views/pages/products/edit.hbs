<h1 class="mb-4">Edit Produk</h1>

{{#if pesanError.length}}

<div class="alert alert-danger">

    <ul>

        {{#each pesanError}}
        <li>{{this}}</li>
        {{/each}}

    </ul>

</div>

{{/if}}

<form action="/produk/edit/{{product.id}}" method="POST">

    <div class="mb-3">

        <label class="form-label">Kategori</label>

        <select
            name="category_id"
            class="form-select">

            {{#each categories}}

            <option
                value="{{id}}"
                {{isSelected id ../product.category_id}}>

                {{nama_kategori}}

            </option>

            {{/each}}

        </select>

    </div>

    <div class="mb-3">

        <label class="form-label">Nama Produk</label>

        <input
            type="text"
            name="nama_produk"
            class="form-control"
            value="{{product.nama_produk}}">

    </div>

    <div class="mb-3">

        <label class="form-label">Harga</label>

        <input
            type="number"
            name="harga"
            class="form-control"
            value="{{product.harga}}">

    </div>

    <div class="mb-3">

        <label class="form-label">Stok</label>

        <input
            type="number"
            name="stok"
            class="form-control"
            value="{{product.stok}}">

    </div>

    <button class="btn btn-primary">
        Update
    </button>

    <a href="/produk/list" class="btn btn-secondary">
        Kembali
    </a>

</form>