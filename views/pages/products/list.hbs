<div class="d-flex justify-content-between align-items-center mb-3">
    <h1>Data Produk</h1>

    <a href="/produk/create" class="btn btn-primary">
        Tambah Produk
    </a>
</div>

{{#if pesanSukses}}
<div class="alert alert-success">
    {{pesanSukses}}
</div>
{{/if}}

<table class="table table-bordered table-hover">

    <thead class="table-dark">

        <tr>
            <th>No</th>
            <th>Kategori</th>
            <th>Nama Produk</th>
            <th>Harga</th>
            <th>Stok</th>
            <th width="180">Aksi</th>
        </tr>

    </thead>

    <tbody>

        {{#each produk}}

        <tr>

            <td>{{inc @index}}</td>

            <td>{{this.nama_kategori}}</td>

            <td>{{this.nama_produk}}</td>

            <td>Rp {{this.harga}}</td>

            <td>{{this.stok}}</td>

            <td>

                <a href="/produk/edit/{{this.id}}" class="btn btn-warning btn-sm">
                    Edit
                </a>

                <a href="/produk/delete/{{this.id}}"
                    class="btn btn-danger btn-sm"
                    onclick="return confirm('Yakin ingin menghapus produk ini?')">

                    Hapus

                </a>

            </td>

        </tr>

        {{/each}}

    </tbody>

</table>