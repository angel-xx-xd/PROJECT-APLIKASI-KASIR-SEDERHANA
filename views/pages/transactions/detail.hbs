<h2 class="mb-4">Detail Transaksi</h2>

<div class="card mb-3">

    <div class="card-body">

        <p>
            <strong>ID Transaksi :</strong>
            {{transaksi.id}}
        </p>

        <p>
            <strong>Tanggal :</strong>
            {{transaksi.tanggal}}
        </p>

        <p>
            <strong>Kasir :</strong>
            {{transaksi.nama}}
        </p>

    </div>

</div>

<table class="table table-bordered">

    <thead class="table-dark">

        <tr>
            <th>No</th>
            <th>Produk</th>
            <th>Harga</th>
            <th>Qty</th>
            <th>Subtotal</th>
        </tr>

    </thead>

    <tbody>

        {{#each detail}}

        <tr>

            <td>{{inc @index}}</td>
            <td>{{nama_produk}}</td>
            <td>Rp {{harga}}</td>
            <td>{{qty}}</td>
            <td>Rp {{subtotal}}</td>

        </tr>

        {{/each}}

    </tbody>

</table>

<div class="text-end mt-3">

    <h4>Total : Rp {{transaksi.total}}</h4>

</div>

<a href="/transaksi/list" class="btn btn-secondary">
    Kembali
</a>